# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CRAMLY_ALLOW_DEMO_MODE=false

# Backend
CRAMLY_ENV=development
# Development-only RAG inspector. Keep disabled for beta/production.
CRAMLY_ENABLE_DEV_RAG=true
# Optional beta invite gate. Leave unset for open registration.
CRAMLY_INVITE_CODE=
CORS_ORIGINS=http://localhost:3000
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|\[::1\])(:\d+)?
DATABASE_URL=postgresql://cramly:cramly@postgres:5432/cramly
LOCAL_STORAGE_PATH=storage
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=10080

# S3-compatible storage. Docker Compose points these at MinIO.
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=cramly-uploads

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Development-only RAG inspector UI. Keep disabled for beta/production.
NEXT_PUBLIC_ENABLE_DEV_RAG=true
# Show the invite-code field on registration.
NEXT_PUBLIC_REQUIRE_INVITE_CODE=false
